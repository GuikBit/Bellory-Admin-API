# ========================================
# .env de PRODUCAO do Bellory-Admin-API
# Copiar para .env no servidor (/opt/api-admin/.env) e preencher.
# ========================================

# Postgres - mesmo banco do Bellory-API (split de codigo, banco compartilhado)
DB_PROD_USER=bellory_prod
DB_PROD_PASSWORD=

# JWT - DEVE ser identico ao secret do Bellory-API para que tokens sejam validos
# nos dois projetos (mesmo HMAC256 secret).
API_SECURITY_TOKEN_SECRET=
API_SECURITY_TOKEN_EXPIRATION=36000

# Payment API (gateway externo de assinaturas/cobranca)
PAYMENT_API_URL=https://pay-api.bellory.com.br
PAYMENT_API_KEY=
PAYMENT_API_COMPANY_ID=4
PAYMENT_API_TIMEOUT_MS=3000

# Cache TTL (admin e dono do cache Redis)
PAYMENT_CACHE_FRESH_TTL_SECONDS=300
PAYMENT_CACHE_STALE_TTL_SECONDS=86400

# Redis - servico interno do compose admin (container `bellory_admin_redis`,
# resolvido por DNS docker como `redis`). NAO mexer em REDIS_HOST/REDIS_PORT
# aqui — sao definidos no docker-compose.yml. So preencher REDIS_PASSWORD
# se for ativar autenticacao no Redis (default: sem password em prod isolado).
REDIS_PASSWORD=

# Email (notificacoes de cobranca/assinatura - admin envia email pra org)
EMAIL_USERNAME=contato@bellory.com.br
EMAIL_PASSWORD=

# Spring profile (sempre 'prod' no servidor)
SPRING_PROFILES_ACTIVE=prod
